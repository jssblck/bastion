---
const repo = "https://github.com/jssblck/bastion";
const unix =
  "curl -sSfL https://raw.githubusercontent.com/jssblck/bastion/main/scripts/install.sh | bash";
const win =
  "irm https://raw.githubusercontent.com/jssblck/bastion/main/scripts/install.ps1 | iex";
---

<section class="section install" id="install">
  <div class="container install-wrap">
    <div class="install-card" data-reveal>
      <div class="install-rule" aria-hidden="true"></div>
      <h2 class="install-title">From nothing to your first gate in five minutes.</h2>
      <p class="install-lede">
        The installer detects your platform, downloads the matching release,
        verifies its SHA-256 checksum, and puts <span class="mono">bastion</span>
        on your <span class="mono">PATH</span>. It fails closed on any checksum
        problem.
      </p>

      <div class="install-blocks">
        <div class="install-block">
          <span class="install-os">macOS &middot; Linux</span>
          <div class="install-cmd-row">
            <code class="install-cmd" id="install-unix">{unix}</code>
            <button
              class="copy-btn"
              type="button"
              data-copy="install-unix"
              aria-label="Copy the macOS and Linux install command"
            >
              <svg class="copy-ic copy-ic--clip" viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
                <rect x="5.5" y="5.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect>
                <path d="M3.5 10.5H3a1.5 1.5 0 0 1-1.5-1.5V3A1.5 1.5 0 0 1 3 1.5h6A1.5 1.5 0 0 1 10.5 3v.5" stroke="currentColor" stroke-width="1.4"></path>
              </svg>
              <svg class="copy-ic copy-ic--check" viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
                <path d="M3 8.4l3.2 3.2L13 4.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
        </div>
        <div class="install-block">
          <span class="install-os">Windows</span>
          <div class="install-cmd-row">
            <code class="install-cmd" id="install-win">{win}</code>
            <button
              class="copy-btn"
              type="button"
              data-copy="install-win"
              aria-label="Copy the Windows PowerShell install command"
            >
              <svg class="copy-ic copy-ic--clip" viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
                <rect x="5.5" y="5.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect>
                <path d="M3.5 10.5H3a1.5 1.5 0 0 1-1.5-1.5V3A1.5 1.5 0 0 1 3 1.5h6A1.5 1.5 0 0 1 10.5 3v.5" stroke="currentColor" stroke-width="1.4"></path>
              </svg>
              <svg class="copy-ic copy-ic--check" viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
                <path d="M3 8.4l3.2 3.2L13 4.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="install-next">
        <p>
          Install the agent skill so your coding agents know how to drive Bastion
          (commit what it writes), then loop a reviewer until the gate is green:
        </p>
        <pre class="install-term"><code><span class="it-prompt">$</span> bastion skills install
<span class="it-prompt">$</span> bastion review --base main</code></pre>
      </div>

      <div class="install-links">
        <a href={`${repo}/blob/main/docs/user-guide/getting-started.md`} class="btn btn--primary">Read the getting-started guide</a>
        <a href={repo} class="btn btn--ghost" rel="noopener">Browse the source</a>
      </div>
    </div>
  </div>
</section>

<style>
  .install {
    padding-block: clamp(3.5rem, 2rem + 6vw, 7rem);
  }
  /* wide enough to hold the longest install command (~91 chars) on one line
     at desktop widths; the command still wraps gracefully on smaller screens */
  .install-wrap {
    max-width: 64rem;
  }
  .install-card {
    position: relative;
    background: var(--paper-raised);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-3);
    padding: clamp(1.5rem, 1rem + 3vw, 3rem);
    box-shadow: var(--shadow-2);
  }
  .install-rule {
    width: 3rem;
    height: 3px;
    background: var(--pass);
    border-radius: 2px;
    margin-bottom: 1.5rem;
  }
  .install-title {
    font-size: var(--text-xl);
    max-width: 20ch;
  }
  .install-lede {
    margin-top: 1rem;
    max-width: var(--measure);
    font-size: var(--text-base);
    color: var(--ink-2);
  }

  /* one block per row, so the whole command is always visible */
  .install-blocks {
    margin-top: 1.75rem;
    display: grid;
    gap: 1.25rem;
  }
  .install-block {
    display: grid;
    gap: 0.5rem;
  }
  .install-os {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-3);
  }
  .install-cmd-row {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-2);
    overflow: hidden;
    background: var(--paper);
  }
  .install-cmd {
    flex: 1;
    min-width: 0;
    padding: 0.8rem 0.9rem;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--ink);
    /* show the full command: wrap rather than truncate or scroll */
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .copy-btn {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-left: 1px solid var(--line);
    background: var(--paper-2);
    color: var(--ink-2);
    padding-inline: 0.9rem;
    cursor: pointer;
    transition: background-color var(--dur-1) var(--ease-out),
      color var(--dur-1) var(--ease-out);
  }
  .copy-btn:hover {
    background: var(--steel-bg);
    color: var(--steel-deep);
  }
  .copy-btn[data-copied] {
    background: var(--pass-bg);
    color: var(--pass-ink);
  }
  .copy-ic--check {
    display: none;
  }
  .copy-btn[data-copied] .copy-ic--clip {
    display: none;
  }
  .copy-btn[data-copied] .copy-ic--check {
    display: block;
  }

  .install-next {
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .install-next p {
    font-size: var(--text-sm);
    color: var(--ink-2);
    margin-bottom: 0.6rem;
  }
  .install-term {
    background: var(--ink);
    border-radius: var(--radius-2);
    padding: 0.8rem 1rem;
    font-size: 0.82rem;
    overflow-x: auto;
  }
  .install-term code {
    color: var(--ink-inverse);
  }
  .it-prompt {
    color: oklch(0.6 0.1 250);
    user-select: none;
    margin-right: 0.5rem;
  }

  .install-links {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
