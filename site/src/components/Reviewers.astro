---
import SectionHeading from "./SectionHeading.astro";

interface Reviewer {
  name: string;
  concern: string;
  trigger: string;
  mode: "gate" | "advisor";
}

// Drawn verbatim in spirit from this repo's own bastion/reviewers.yaml.
const reviewers: Reviewer[] = [
  {
    name: "single-responsibility",
    concern: "No one file concentrates multiple unrelated concerns.",
    trigger: "src/**/*.rs",
    mode: "gate",
  },
  {
    name: "error-handling",
    concern: "No recoverable error can panic in production code.",
    trigger: "src/**/*.rs",
    mode: "gate",
  },
  {
    name: "api-compatibility",
    concern: "Public API changes stay backward-compatible.",
    trigger: "src/api/**",
    mode: "gate",
  },
  {
    name: "release-surface-robustness",
    concern: "Installers verify checksums and fail closed on any mismatch.",
    trigger: "scripts/**",
    mode: "gate",
  },
  {
    name: "parse-dont-validate",
    concern: "Boundary data is parsed once into a precise type.",
    trigger: "src/**/*.rs",
    mode: "advisor",
  },
  {
    name: "test-coverage",
    concern: "New or changed behavior is covered by tests.",
    trigger: "src/**/*.rs",
    mode: "advisor",
  },
  {
    name: "docs-in-sync",
    concern: "User-visible changes update the matching docs.",
    trigger: "docs/**/*.md",
    mode: "advisor",
  },
];
---

<section class="section reviewers" id="reviewers">
  <div class="container">
    <SectionHeading title="One concern per reviewer.">
      A reviewer is a focused fitness function: a prompt, a trigger, a mode. A
      cross-cutting property like tenant isolation or migration safety is just
      another reviewer whose single concern is that property.
    </SectionHeading>

    <div class="registry" data-reveal>
      <table class="registry-table">
        <colgroup>
          <col class="col-name" />
          <col class="col-concern" />
          <col class="col-trigger" />
          <col class="col-mode" />
        </colgroup>
        <thead>
          <tr class="registry-head">
            <th scope="col">reviewer</th>
            <th scope="col">concern</th>
            <th scope="col">trigger</th>
            <th scope="col" class="registry-head-mode">mode</th>
          </tr>
        </thead>
        <tbody>
          {
            reviewers.map((r) => (
              <tr class="registry-row">
                <td class="r-name">{r.name}</td>
                <td class="r-concern">{r.concern}</td>
                <td class="r-trigger">
                  <code>{r.trigger}</code>
                </td>
                <td class="r-mode">
                  <span class={`pill pill--${r.mode}`}>
                    <span class="pill-dot" />
                    {r.mode}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="reviewers-notes">
      <div class="rn" data-reveal>
        <h3>Gates block. Advisors comment.</h3>
        <p>
          A <span class="mono">gate</span> holds the merge until it passes. An
          <span class="mono">advisor</span> reports findings without blocking. Same
          reviewer shape, different authority, your call per concern.
        </p>
      </div>
      <div class="rn" data-reveal style="--reveal-delay:80ms">
        <h3>Declarative and static</h3>
        <p>
          Reviewers live in one file, not generated by code. That keeps them
          reviewable and the trigger set stable, so a change to review policy is
          a diff you can read.
        </p>
      </div>
      <div class="rn" data-reveal style="--reveal-delay:160ms">
        <h3>Composable and parallel</h3>
        <p>
          They run independently and aggregate at the end. Add a reviewer for a
          new concern without touching the others; a slow one never blocks a
          fast one.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .registry {
    margin-top: clamp(2rem, 1rem + 3vw, 3rem);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-3);
    overflow: hidden;
    background: var(--paper-raised);
    box-shadow: var(--shadow-1);
  }
  /* One table, one set of column tracks (set on the colgroup), so every row
     aligns into the same columns no matter how wide a single cell's content
     is. Independent per-row grids could drift; a table cannot. */
  .registry-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .col-name {
    width: 14rem;
  }
  .col-trigger {
    width: 11rem;
  }
  .col-mode {
    width: 6.5rem;
  }
  .registry-head th {
    background: var(--paper-2);
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: var(--text-xs);
    color: var(--ink-3);
    letter-spacing: 0.03em;
    text-align: left;
    padding: 0.85rem 0.5rem;
  }
  .registry-head th:first-child {
    padding-left: 1.1rem;
  }
  .registry-head th:last-child {
    padding-right: 1.1rem;
  }
  .registry-head-mode {
    text-align: right;
  }
  .registry-row {
    transition: background-color var(--dur-1) var(--ease-out);
  }
  .registry-row:hover {
    background: color-mix(in oklch, var(--steel-bg) 35%, var(--paper-raised));
  }
  .registry-row td {
    padding: 0.85rem 0.5rem;
    vertical-align: middle;
  }
  .registry-row td:first-child {
    padding-left: 1.1rem;
  }
  .registry-row td:last-child {
    padding-right: 1.1rem;
  }
  .registry-row:not(:first-child) td {
    border-top: 1px solid var(--line);
  }
  .r-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
    word-break: break-word;
  }
  .r-concern {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }
  .r-trigger code {
    font-size: 0.78rem;
    color: var(--steel);
    background: var(--steel-bg);
    padding: 0.2em 0.45em;
    border-radius: var(--radius-1);
    overflow-wrap: anywhere;
  }
  .r-mode {
    text-align: right;
  }

  /* responsive: collapse each row into a stacked record */
  @media (max-width: 860px) {
    .registry-table,
    .registry-table tbody {
      display: block;
    }
    .registry-head {
      display: none;
    }
    .registry-row {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "name mode"
        "concern concern"
        "trigger trigger";
      gap: 0.55rem 1rem;
      align-items: center;
      padding: 0.85rem 1.1rem;
    }
    .registry-row td,
    .registry-row td:first-child,
    .registry-row td:last-child {
      padding: 0;
      border-top: 0;
    }
    .registry-row:not(:first-child) {
      border-top: 1px solid var(--line);
    }
    .r-name {
      grid-area: name;
    }
    .r-mode {
      grid-area: mode;
      text-align: left;
      justify-self: end;
    }
    .r-concern {
      grid-area: concern;
    }
    .r-trigger {
      grid-area: trigger;
    }
  }

  .reviewers-notes {
    margin-top: clamp(1.75rem, 1rem + 2vw, 2.5rem);
    display: grid;
    gap: 1.5rem 2rem;
  }
  @media (min-width: 760px) {
    .reviewers-notes {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .rn h3 {
    font-size: var(--text-md);
    margin-bottom: 0.5rem;
  }
  .rn p {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }
</style>
