---
import SectionHeading from "./SectionHeading.astro";

interface Reviewer {
  name: string;
  concern: string;
  trigger: string;
  mode: "gate" | "advisor";
}

// Drawn verbatim in spirit from this repo's own bastion/reviewers.yaml.
const reviewers: Reviewer[] = [
  {
    name: "single-responsibility",
    concern: "No one file concentrates multiple unrelated concerns.",
    trigger: "src/**/*.rs",
    mode: "gate",
  },
  {
    name: "error-handling",
    concern: "No recoverable error can panic in production code.",
    trigger: "src/**/*.rs",
    mode: "gate",
  },
  {
    name: "api-compatibility",
    concern: "Public API changes stay backward-compatible.",
    trigger: "src/api/**",
    mode: "gate",
  },
  {
    name: "release-surface-robustness",
    concern: "Installers verify checksums and fail closed on any mismatch.",
    trigger: "scripts/**",
    mode: "gate",
  },
  {
    name: "parse-dont-validate",
    concern: "Boundary data is parsed once into a precise type.",
    trigger: "src/**/*.rs",
    mode: "advisor",
  },
  {
    name: "test-coverage",
    concern: "New or changed behavior is covered by tests.",
    trigger: "src/**/*.rs",
    mode: "advisor",
  },
  {
    name: "docs-in-sync",
    concern: "User-visible changes update the matching docs.",
    trigger: "docs/**/*.md",
    mode: "advisor",
  },
];
---

<section class="section reviewers" id="reviewers">
  <div class="container">
    <SectionHeading title="One concern per reviewer.">
      A reviewer is a focused fitness function: a prompt, a trigger, a mode. The
      unit of the system is the reviewer, not the review. A cross-cutting
      property like tenant isolation or migration safety isn't special, it's
      just another reviewer whose single concern is that property.
    </SectionHeading>

    <div class="registry" data-reveal>
      <div class="registry-head" aria-hidden="true">
        <span>reviewer</span>
        <span>concern</span>
        <span>trigger</span>
        <span class="registry-head-mode">mode</span>
      </div>
      <ul class="registry-list">
        {
          reviewers.map((r) => (
            <li class="registry-row">
              <span class="r-name">{r.name}</span>
              <span class="r-concern">{r.concern}</span>
              <span class="r-trigger">
                <code>{r.trigger}</code>
              </span>
              <span class="r-mode">
                <span class={`pill pill--${r.mode}`}>
                  <span class="pill-dot" />
                  {r.mode}
                </span>
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="reviewers-notes">
      <div class="rn" data-reveal>
        <h3>Gates block. Advisors comment.</h3>
        <p>
          A <span class="mono">gate</span> holds the merge until it passes. An
          <span class="mono">advisor</span> reports findings without blocking. Same
          reviewer shape, different authority, your call per concern.
        </p>
      </div>
      <div class="rn" data-reveal style="--reveal-delay:80ms">
        <h3>Declarative and static.</h3>
        <p>
          Reviewers live in one file, not generated by code. That keeps them
          reviewable and the trigger set stable, so a change to review policy is
          a diff you can read.
        </p>
      </div>
      <div class="rn" data-reveal style="--reveal-delay:160ms">
        <h3>Composable and parallel.</h3>
        <p>
          They run independently and aggregate at the end. Add a reviewer for a
          new concern without touching the others; a slow one never blocks a
          fast one.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .registry {
    margin-top: clamp(2rem, 1rem + 3vw, 3rem);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-3);
    overflow: hidden;
    background: var(--paper-raised);
    box-shadow: var(--shadow-1);
  }
  .registry-head,
  .registry-row {
    display: grid;
    grid-template-columns: 14rem 1fr 11rem 6.5rem;
    gap: 1rem;
    align-items: center;
    padding: 0.85rem 1.1rem;
  }
  .registry-head {
    background: var(--paper-2);
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-3);
    letter-spacing: 0.03em;
  }
  .registry-head-mode {
    text-align: right;
  }
  .registry-list {
    list-style: none;
  }
  .registry-row + .registry-row {
    border-top: 1px solid var(--line);
  }
  .registry-row {
    transition: background-color var(--dur-1) var(--ease-out);
  }
  .registry-row:hover {
    background: color-mix(in oklch, var(--steel-bg) 35%, var(--paper-raised));
  }
  .r-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
  }
  .r-concern {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }
  .r-trigger code {
    font-size: 0.78rem;
    color: var(--steel);
    background: var(--steel-bg);
    padding: 0.2em 0.45em;
    border-radius: var(--radius-1);
  }
  .r-mode {
    display: flex;
    justify-content: flex-end;
  }

  /* responsive: collapse the grid into stacked records */
  @media (max-width: 860px) {
    .registry-head {
      display: none;
    }
    .registry-row {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "name mode"
        "concern concern"
        "trigger trigger";
      gap: 0.55rem 1rem;
    }
    .r-name {
      grid-area: name;
    }
    .r-mode {
      grid-area: mode;
    }
    .r-concern {
      grid-area: concern;
    }
    .r-trigger {
      grid-area: trigger;
    }
  }

  .reviewers-notes {
    margin-top: clamp(1.75rem, 1rem + 2vw, 2.5rem);
    display: grid;
    gap: 1.5rem 2rem;
  }
  @media (min-width: 760px) {
    .reviewers-notes {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .rn h3 {
    font-size: var(--text-md);
    margin-bottom: 0.5rem;
  }
  .rn p {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }
</style>
