---
import SectionHeading from "./SectionHeading.astro";

interface Row {
  name: string;
  mode: "gate" | "advisor";
  happened: string;
  state: "pass" | "block";
  countsAs: "pass" | "block" | "open";
}

const rows: Row[] = [
  { name: "single-responsibility", mode: "gate", happened: "returned pass", state: "pass", countsAs: "pass" },
  { name: "error-handling", mode: "gate", happened: "returned block", state: "block", countsAs: "block" },
  { name: "e2e-checkout-flow", mode: "gate", happened: "timed out", state: "block", countsAs: "block" },
  { name: "migration-safety", mode: "gate", happened: "crashed", state: "block", countsAs: "block" },
  { name: "no-verdict", mode: "gate", happened: "malformed output", state: "block", countsAs: "block" },
  { name: "test-coverage", mode: "advisor", happened: "errored", state: "pass", countsAs: "open" },
];

const countLabel: Record<Row["countsAs"], string> = {
  pass: "pass",
  block: "block",
  open: "skipped",
};
---

<section class="section gate" id="gate">
  <div class="container">
    <SectionHeading title="How the gate aggregates">
      Reviewers run in parallel with per-reviewer timeouts; their verdicts
      aggregate into one decision. A gate that crashes, times out, or can't
      produce a valid verdict resolves to <strong>block</strong>, never a silent
      pass. Advisors are best-effort: when one fails, it's ignored.
    </SectionHeading>

    <div class="gate-layout">
      <div class="ledger" data-reveal>
        <table class="ledger-table">
          <thead>
            <tr class="ledger-head">
              <th scope="col">reviewer</th>
              <th scope="col">what happened</th>
              <th scope="col" class="ledger-head-result">counts as</th>
            </tr>
          </thead>
          <tbody>
            {
              rows.map((r, i) => (
                <tr class="ledger-row" style={`--i:${i}`}>
                  <td class="l-name">
                    <span class="l-name-inner">
                      <span class={`mode-tick mode-tick--${r.mode}`} aria-hidden="true" />
                      {r.name}
                      {r.mode === "advisor" && <em class="l-advisor">advisor</em>}
                    </span>
                  </td>
                  <td class="l-happened">{r.happened}</td>
                  <td class="l-result">
                    <span class="l-result-inner">
                      <span class="l-arrow" aria-hidden="true">&rarr;</span>
                      <span class={`pill pill--${r.countsAs === "open" ? "neutral" : r.countsAs === "pass" ? "pass" : "block"}`}>
                        <span class="pill-dot" />
                        {countLabel[r.countsAs]}
                      </span>
                    </span>
                  </td>
                </tr>
              ))
            }
          </tbody>
          <tfoot>
            <tr>
              <td class="ledger-foot-cell" colspan="3">
                <div class="ledger-foot">
                  <div class="ledger-foot-text">
                    <span class="ledger-q">Every gate returned pass?</span>
                    <span class="ledger-a">No. Four gates resolved to block.</span>
                  </div>
                  <div class="aggregate">
                    <span class="aggregate-label">merge gate</span>
                    <span class="pill pill--block aggregate-pill">
                      <span class="pill-dot" />block
                    </span>
                  </div>
                </div>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>

      <aside class="gate-laws" aria-label="Failure semantics">
        <div class="law" data-reveal>
          <span class="law-key">timeout</span>
          <span class="law-arrow" aria-hidden="true">&rarr;</span>
          <span class="law-val law-val--block">block</span>
        </div>
        <div class="law" data-reveal style="--reveal-delay:60ms">
          <span class="law-key">crash</span>
          <span class="law-arrow" aria-hidden="true">&rarr;</span>
          <span class="law-val law-val--block">block</span>
        </div>
        <div class="law" data-reveal style="--reveal-delay:120ms">
          <span class="law-key">no valid verdict</span>
          <span class="law-arrow" aria-hidden="true">&rarr;</span>
          <span class="law-val law-val--block">block</span>
        </div>
        <div class="law law--open" data-reveal style="--reveal-delay:180ms">
          <span class="law-key">advisor error</span>
          <span class="law-arrow" aria-hidden="true">&rarr;</span>
          <span class="law-val law-val--open">ignored</span>
        </div>
        <p class="gate-laws-note" data-reveal style="--reveal-delay:220ms">
          Gates fail closed. Advisors fail open.
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .gate {
    background:
      linear-gradient(var(--paper-2), var(--paper-2)) padding-box;
    border-block: 1px solid var(--line);
  }
  .gate-layout {
    margin-top: clamp(2rem, 1rem + 3vw, 3rem);
    display: grid;
    gap: 1.5rem;
    align-items: start;
    grid-template-columns: minmax(0, 1fr);
  }
  @media (min-width: 900px) {
    .gate-layout {
      grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    }
  }

  .ledger {
    background: var(--paper-raised);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-3);
    overflow: hidden;
    box-shadow: var(--shadow-2);
  }
  /* One table with one set of column tracks, so every row shares the same
     column widths. A wider cell (the advisor badge) can't shift a single row
     out of alignment the way independent per-row grids could. */
  .ledger-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: auto;
  }
  .ledger-head th {
    background: var(--ink);
    color: var(--ink-inverse);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.03em;
    text-align: left;
    padding: 0.8rem 1.1rem;
  }
  .ledger-head-result {
    text-align: right;
  }
  .ledger-row td {
    padding: 0.8rem 1.1rem;
    vertical-align: middle;
  }
  .ledger-row:not(:first-child) td {
    border-top: 1px solid var(--line);
  }
  .l-name {
    width: 46%;
  }
  .l-name-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink);
    flex-wrap: wrap;
  }
  .mode-tick {
    width: 0.4rem;
    height: 1rem;
    border-radius: 1px;
    flex: none;
  }
  .mode-tick--gate {
    background: var(--ink-3);
  }
  .mode-tick--advisor {
    background: var(--advisor);
  }
  .l-advisor {
    font-family: var(--font-sans);
    font-style: normal;
    font-size: 0.64rem;
    color: var(--advisor-ink);
    background: var(--advisor-bg);
    border: 1px solid var(--advisor-line);
    padding: 0.05em 0.4em;
    border-radius: var(--radius-1);
  }
  .l-happened {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }
  .l-result {
    text-align: right;
    white-space: nowrap;
    width: 1%;
  }
  .l-result-inner {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
  }
  .l-arrow {
    color: var(--ink-3);
    font-size: 0.85rem;
  }

  .ledger-foot-cell {
    padding: 0;
  }
  .ledger-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1rem 1.1rem;
    background: var(--block-bg);
    border-top: 1px solid var(--block-line);
  }
  .ledger-foot-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .ledger-q {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }
  .ledger-a {
    font-size: var(--text-sm);
    font-weight: 560;
    color: var(--block-ink);
  }
  .aggregate {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .aggregate-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-3);
  }
  .aggregate-pill {
    font-size: var(--text-sm);
    padding: 0.5em 0.8em;
  }

  /* failure-semantics laws */
  .gate-laws {
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }
  .law {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.95rem;
    background: var(--paper-raised);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  .law-key {
    color: var(--ink-2);
  }
  .law-arrow {
    color: var(--ink-3);
    margin-left: auto;
  }
  .law-val {
    font-weight: 600;
  }
  .law-val--block {
    color: var(--block-ink);
  }
  .law-val--open {
    color: var(--ink-3);
  }
  .law--open {
    border-style: dashed;
    background: var(--paper-2);
  }
  .gate-laws-note {
    margin-top: 0.4rem;
    font-size: var(--text-sm);
    color: var(--ink-2);
  }

  @media (max-width: 540px) {
    /* Drop the middle column; auto table layout collapses it once every
       cell in it is hidden. */
    .ledger-head th:nth-child(2),
    .l-happened {
      display: none;
    }
    .l-name {
      width: auto;
    }
  }

  /* reveal stagger for rows; applied to the cells because transforms on
     table-row boxes are not reliable across browsers */
  @media (prefers-reduced-motion: no-preference) {
    .js .ledger.is-in .ledger-row td {
      animation: row-in var(--dur-2) var(--ease-out) backwards;
      animation-delay: calc(var(--i) * 70ms + 120ms);
    }
    @keyframes row-in {
      from {
        opacity: 0;
        transform: translateX(-6px);
      }
    }
  }
</style>
