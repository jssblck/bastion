---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const repo = "https://github.com/jssblck/bastion";
const ciGuide = "/guide/continuous-integration";

// GitHub's "new GitHub App" forms. Personal accounts and organizations have
// separate URLs; the org form takes the org login in the path. We link people
// straight to these and walk them through filling the form by hand. We do not
// use GitHub's app-manifest flow: completing it requires a backend to exchange
// the temporary code for the app's credentials, and Bastion deliberately
// custodies no credentials and serves no such backend, so a hand walkthrough is
// the honest path.
const newAppPersonal = "https://github.com/settings/apps/new";

// The repository permissions the report step needs, and nothing else. `checks`
// to post the per-reviewer and aggregate check runs, `pull_requests` to write
// the sticky comment, `contents` to read the diff. No webhook: Bastion runs in
// your CI, it does not receive events.
const permissions = [
  { name: "Checks", access: "Read and write" },
  { name: "Pull requests", access: "Read and write" },
  { name: "Contents", access: "Read-only" },
];

const title = "Set up the Bastion GitHub App";
const description =
  "Create a small GitHub App by hand so Bastion's per-reviewer and aggregate check runs render under their own name instead of clustering beneath another workflow's checks.";
---

<Base title={title} description={description}>
  <Nav />
  <main id="main">
    <section class="section app">
      <div class="container container-narrow">
        <h1 class="app-title" data-reveal>Set up the Bastion GitHub App</h1>
        <p class="app-lede" data-reveal>
          Bastion can optionally post checks and comments through a GitHub App.
          This page shows how to set it up.
        </p>

        <!-- Step 1: create the app by hand. -->
        <div class="app-card" data-reveal>
          <div class="app-rule" aria-hidden="true"></div>
          <h2 class="app-card-title">1. Create the app on GitHub</h2>
          <p class="app-card-text">
            Open GitHub's new-app form. For an org, use
            <span class="mono"
              >github.com/organizations/<span class="app-var">YOUR-ORG</span
              >/settings/apps/new</span
            >.
          </p>
          <p class="app-card-text">
            <a
              href={newAppPersonal}
              class="btn btn--primary app-cta"
              target="_blank"
              rel="noopener"
            >
              Open the new-app form
            </a>
          </p>

          <ol class="app-steps">
            <li>
              <strong>Name.</strong> This is what the checks group under, for
              example <span class="mono">YourOrg's Bastion</span>. Must be
              globally unique.
            </li>
            <li>
              <strong>Webhook.</strong> Uncheck <strong>Active</strong>.
            </li>
            <li>
              <strong>Repository permissions.</strong> Set these, leave the rest
              at <span class="mono">No access</span>:
              <div class="app-perms">
                {
                  permissions.map((p) => (
                    <div class="app-perm">
                      <span class="app-perm-name">{p.name}</span>
                      <span class="app-perm-access">{p.access}</span>
                    </div>
                  ))
                }
              </div>
            </li>
            <li>
              Click <strong>Create GitHub App</strong>.
            </li>
          </ol>
        </div>

        <!-- Step 2: capture credentials. -->
        <div class="app-card" data-reveal>
          <div class="app-rule" aria-hidden="true"></div>
          <h2 class="app-card-title">2. Capture the app's credentials</h2>
          <p class="app-card-text">
            Click <strong>Generate a private key</strong> (a
            <span class="mono">.pem</span> downloads) and note the
            <strong>App ID</strong>. Then open <strong>Install App</strong> and
            install it on the repositories that run Bastion.
          </p>
        </div>

        <!-- Step 3: store the secrets. -->
        <div class="app-card" data-reveal>
          <div class="app-rule" aria-hidden="true"></div>
          <h2 class="app-card-title">3. Store the two secrets</h2>
          <p class="app-card-text">
            Add these as Actions secrets, named exactly:
          </p>
          <div class="app-secrets">
            <div class="app-secret">
              <code class="app-secret-name" id="secret-id">BASTION_APP_ID</code>
              <button
                class="copy-btn"
                type="button"
                data-copy="secret-id"
                aria-label="Copy the secret name BASTION_APP_ID"
              >
                <svg class="copy-ic copy-ic--clip" viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
                  <rect x="5.5" y="5.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect>
                  <path d="M3.5 10.5H3a1.5 1.5 0 0 1-1.5-1.5V3A1.5 1.5 0 0 1 3 1.5h6A1.5 1.5 0 0 1 10.5 3v.5" stroke="currentColor" stroke-width="1.4"></path>
                </svg>
                <svg class="copy-ic copy-ic--check" viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
                  <path d="M3 8.4l3.2 3.2L13 4.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </button>
              <span class="app-secret-desc">the numeric App ID</span>
            </div>
            <div class="app-secret">
              <code class="app-secret-name" id="secret-key">BASTION_APP_PRIVATE_KEY</code>
              <button
                class="copy-btn"
                type="button"
                data-copy="secret-key"
                aria-label="Copy the secret name BASTION_APP_PRIVATE_KEY"
              >
                <svg class="copy-ic copy-ic--clip" viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
                  <rect x="5.5" y="5.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect>
                  <path d="M3.5 10.5H3a1.5 1.5 0 0 1-1.5-1.5V3A1.5 1.5 0 0 1 3 1.5h6A1.5 1.5 0 0 1 10.5 3v.5" stroke="currentColor" stroke-width="1.4"></path>
                </svg>
                <svg class="copy-ic copy-ic--check" viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true">
                  <path d="M3 8.4l3.2 3.2L13 4.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </button>
              <span class="app-secret-desc">the full contents of the downloaded .pem</span>
            </div>
          </div>
          <p class="app-card-note">
            For Dependabot PRs, set them in the Dependabot secret store too.
          </p>
        </div>

        <!-- Done. -->
        <div class="app-done" data-reveal>
          <div class="app-links">
            <a href={ciGuide} class="btn btn--ghost">Continuous integration guide</a>
            <a
              href={`${repo}/blob/main/.github/workflows/bastion.yml`}
              class="btn btn--ghost"
              rel="noopener">See the workflow</a
            >
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .app {
    padding-block: clamp(3rem, 2rem + 5vw, 6rem);
  }
  .app-title {
    margin-top: 0.75rem;
    font-size: var(--text-2xl);
    max-width: 18ch;
  }
  .app-lede {
    margin-top: 1.25rem;
    max-width: var(--measure);
    font-size: var(--text-md);
    color: var(--ink-2);
  }

  .app-card {
    margin-top: 2rem;
    position: relative;
    background: var(--paper-raised);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-3);
    padding: clamp(1.5rem, 1rem + 2.5vw, 2.5rem);
    box-shadow: var(--shadow-2);
  }
  .app-rule {
    width: 2.5rem;
    height: 3px;
    background: var(--steel);
    border-radius: 2px;
    margin-bottom: 1.25rem;
  }
  .app-card-title {
    font-size: var(--text-lg);
  }
  .app-card-text {
    margin-top: 0.85rem;
    max-width: var(--measure);
    font-size: var(--text-base);
    color: var(--ink-2);
  }
  .app-cta {
    margin-top: 0.35rem;
  }
  .app-card-note {
    margin-top: 1.1rem;
    max-width: var(--measure);
    font-size: var(--text-sm);
    color: var(--ink-3);
  }

  .app-var {
    color: var(--steel-deep);
  }

  /* The ordered sub-steps inside "Create the app". */
  .app-steps {
    margin-top: 1.5rem;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.85rem;
    max-width: var(--measure);
    font-size: var(--text-base);
    color: var(--ink-2);
  }
  .app-steps li {
    padding-left: 0.3rem;
  }
  .app-steps strong {
    color: var(--ink);
  }

  /* The required-permissions list inside step 1. */
  .app-perms {
    margin-top: 0.85rem;
    display: grid;
    gap: 0.5rem;
    max-width: 24rem;
  }
  .app-perm {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    background: var(--paper-sunk);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-2);
    padding: 0.5rem 0.75rem;
  }
  .app-perm-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
  }
  .app-perm-access {
    font-size: var(--text-sm);
    color: var(--ink-2);
  }

  .app-secrets {
    margin-top: 1.25rem;
    display: grid;
    gap: 0.85rem;
  }
  .app-secret {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .app-secret-name {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
    background: var(--paper-sunk);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-2);
    padding: 0.45rem 0.7rem;
  }
  .app-secret-desc {
    font-size: var(--text-sm);
    color: var(--ink-3);
  }

  /* Copy button: mirrors the install block's affordance. The clipboard SVG
     swaps to a check when the global [data-copy] handler marks it copied. */
  .copy-btn {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line-strong);
    background: var(--paper-2);
    color: var(--ink-2);
    border-radius: var(--radius-2);
    padding: 0.45rem 0.55rem;
    cursor: pointer;
    transition: background-color var(--dur-1) var(--ease-out),
      color var(--dur-1) var(--ease-out);
  }
  .copy-btn:hover {
    background: var(--steel-bg);
    color: var(--steel-deep);
  }
  .copy-btn[data-copied] {
    background: var(--pass-bg);
    color: var(--pass-ink);
    border-color: var(--pass-line);
  }
  .copy-ic--check {
    display: none;
  }
  .copy-btn[data-copied] .copy-ic--clip {
    display: none;
  }
  .copy-btn[data-copied] .copy-ic--check {
    display: block;
  }

  .app-done {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .app-links {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
